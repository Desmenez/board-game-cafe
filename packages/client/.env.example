# Client (Vite) environment variables

# Cloudinary cloud name used by src/imageMap.ts
# Example: demo
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name


# Server URL used by src/hooks/useSocket.ts
# Example: http://localhost:3001
# For Capacitor Android production builds, set in .env.production (see .env.production.example)
VITE_SERVER_URL=http://localhost:3001

# Must match server ADMIN_SECRET — typed in the home join field to open /admin
# Example: ADMIN$
VITE_ADMIN_SECRET=

# Optional Supabase Auth (Google). Leave empty for guest-only local play.
# See supabase/README.md and docs/adr/0002-supabase-auth-persistence.md
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
