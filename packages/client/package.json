{
  "name": "client",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "pnpm --dir ../.. --filter shared build",
    "build": "tsc -b && vite build && node scripts/check-tailwind-cascade.mjs",
    "preview": "vite preview",
    "cap:sync": "pnpm build && npx cap sync android",
    "cap:open": "npx cap open android",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "cap:icons": "node scripts/generate-app-icons.mjs && capacitor-assets generate --android --iconBackgroundColor '#FFFFFF' --iconBackgroundColorDark '#FFFFFF'"
  },
  "dependencies": {
    "@capacitor/core": "^8.4.2",
    "@dicebear/core": "^10.3.0",
    "@dicebear/styles": "^10.2.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-tabs": "^1.1.14",
    "canvas-confetti": "^1.9.4",
    "lucide-react": "^1.6.0",
    "motion": "^12.38.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.6.0",
    "react-zoom-pan-pinch": "^4.0.3",
    "shared": "workspace:*",
    "socket.io-client": "^4.8.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "vite": "^8.0.1"
  }
}
