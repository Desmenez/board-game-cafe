{
  "name": "board-game",
  "private": true,
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "eslint": "^9.19.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript-eslint": "^8.24.1"
  },
  "scripts": {
    "dev": "pnpm --parallel -r run dev",
    "build": "pnpm -r run build",
    "format": "prettier --write --ignore-path .prettierignore \"**/*.{ts,tsx,js,jsx,css,md,json}\"",
    "format:check": "prettier --check --ignore-path .prettierignore \"**/*.{ts,tsx,js,jsx,css,md,json}\"",
    "lint": "pnpm -r run lint",
    "lint:fix": "pnpm -r run lint:fix",
    "dev:server": "pnpm --filter server dev",
    "dev:client": "pnpm --filter client dev"
  }
}
